{
  "name": "praxis-knowledge-radar",
  "version": "1.0.0",
  "description": "个人知识吸收管线：文章/链接输入 → 归类入库 → 学习内化 → 应用输出",
  "dependencies": {
    "python": {
      "type": "required",
      "version": ">=3.10",
      "description": "Python 运行时",
      "install": "brew install python3",
      "check": "python3 --version",
      "update": "brew upgrade python3",
      "check-latest": "brew info python3"
    },
    "dws": {
      "type": "recommended",
      "description": "钉钉工作空间 CLI，用于拉取群消息",
      "install": "npm install -g dws-cli",
      "check": "dws --version",
      "update": "npm update -g dws-cli",
      "check-latest": "npm info dws-cli version"
    },
    "curl": {
      "type": "recommended",
      "description": "HTTP 客户端，用于抓取 URL 内容",
      "install": "brew install curl",
      "check": "curl --version",
      "update": "brew upgrade curl",
      "check-latest": "brew info curl"
    }
  },
  "capability_tiers": {
    "CORE": {
      "description": "Python stdlib only, zero external deps",
      "features": [
        "radar.py add/list/update",
        "knowledge_ops.py review/lint/grade/dedup/progress/triage",
        "radar_enhanced.py status/next/refs/deps/competitors/summary"
      ]
    },
    "ENHANCED": {
      "description": "Optional CLI tools, graceful degradation when missing",
      "features": [
        "dingtalk_fetch.py (requires dws CLI)",
        "URL content fetching (requires curl)",
        "generate_report_v2.py (requires curl for URL fetching)"
      ]
    },
    "ADVANCED": {
      "description": "External APIs, authenticated services",
      "features": [
        "dingtalk_fetch.py with钉钉 API",
        "dingtalk_notify.py with Webhook",
        "auto_capture.sh with cron job"
      ]
    }
  },
  "scripts": {
    "radar.py": {
      "description": "核心任务管理",
      "tier": "CORE",
      "commands": ["add", "list", "update", "export-md", "seed-mainlines"]
    },
    "knowledge_ops.py": {
      "description": "知识运维",
      "tier": "CORE",
      "commands": ["review", "lint", "grade", "dedup", "progress", "triage"]
    },
    "radar_enhanced.py": {
      "description": "增强查询",
      "tier": "CORE",
      "commands": ["status", "next", "refs", "deps", "competitors", "summary", "sync", "sync-all"]
    },
    "dingtalk_fetch.py": {
      "description": "钉钉消息拉取",
      "tier": "ENHANCED",
      "commands": ["--incremental", "--since", "--dry-run", "--json"]
    },
    "dingtalk_notify.py": {
      "description": "钉钉通知",
      "tier": "ADVANCED",
      "commands": ["setup", "test", "send"]
    },
    "generate_report_v2.py": {
      "description": "报告生成",
      "tier": "ENHANCED",
      "commands": ["--format html", "--format md", "--open", "--output"]
    },
    "auto_capture.sh": {
      "description": "自动捕获",
      "tier": "ADVANCED",
      "commands": ["--notify"]
    },
    "cleanup.sh": {
      "description": "存储清理",
      "tier": "CORE",
      "commands": ["--dry-run"]
    }
  },
  "files": {
    "required": [
      "SKILL.md",
      "deps-manifest.json",
      "scripts/radar.py",
      "scripts/knowledge_ops.py",
      "scripts/radar_enhanced.py"
    ],
    "recommended": [
      "scripts/dingtalk_fetch.py",
      "scripts/dingtalk_notify.py",
      "scripts/generate_report_v2.py",
      "scripts/auto_capture.sh",
      "scripts/cleanup.sh",
      "references/"
    ],
    "optional": [
      "scripts/import-mapping.py",
      "scripts/setup_dingtalk.py",
      "scripts/setup_auto_capture.sh",
      "scripts/scheduled_sync.sh"
    ]
  }
}
