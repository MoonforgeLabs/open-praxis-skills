{
  "name": "praxis-search-hub",
  "version": "0.5",
  "tiers": {
    "CORE": {
      "description": "Python stdlib only, zero external deps",
      "commands": ["status", "doctor", "ratelimit", "gate", "backends", "gh-suggest", "web", "fetch", "research", "catalog"],
      "platforms": ["macos", "linux", "windows"],
      "notes": "Windows: fcntl unavailable, rate limiting degrades"
    },
    "ENHANCED": {
      "description": "Optional CLI tools, graceful degradation when missing",
      "commands": ["gh-lookup", "social"],
      "platforms": ["macos", "linux", "windows"],
      "degradation": "Commands return skipped=true when deps missing"
    },
    "ADVANCED": {
      "description": "External skills or authenticated APIs",
      "commands": ["github-repos", "github-code", "deep-research"],
      "platforms": ["macos", "linux"],
      "notes": "last30days requires Python 3.12+"
    }
  },
  "dependencies": {
    "gh": {
      "type": "brew",
      "tier": "ENHANCED",
      "install": "brew install gh",
      "check": "gh --version",
      "update": "brew upgrade gh",
      "check_latest": "brew info gh",
      "platform": "cross-platform",
      "optional": true
    },
    "mcporter": {
      "type": "npm",
      "tier": "ENHANCED",
      "install": "npm install -g mcporter",
      "check": "mcporter --version",
      "update": "npm update -g mcporter",
      "check_latest": "npm info mcporter version",
      "platform": "cross-platform",
      "optional": true
    },
    "opencli": {
      "type": "npm",
      "tier": "ENHANCED",
      "install": "npm install -g opencli",
      "check": "opencli --version",
      "update": "npm update -g opencli",
      "check_latest": "npm info opencli version",
      "platform": "cross-platform",
      "optional": true
    },
    "agent-reach-cli": {
      "type": "pipx",
      "tier": "ENHANCED",
      "install": "pipx install agent-reach",
      "check": "agent-reach --version",
      "update": "pipx upgrade agent-reach",
      "check_latest": "pip index versions agent-reach",
      "platform": "cross-platform",
      "optional": true
    },
    "agent-reach-skill": {
      "type": "skills.sh",
      "tier": "ENHANCED",
      "install": "npx skills add panniantong/agent-reach -g",
      "check": "test -d ~/.agents/skills/agent-reach/SKILL.md",
      "update": "npx skills update agent-reach",
      "check_latest": "gh api repos/panniantong/agent-reach/releases/latest --jq .tag_name",
      "platform": "cross-platform",
      "optional": true
    },
    "last30days": {
      "type": "skills.sh",
      "tier": "ADVANCED",
      "install": "npx skills add mvanhorn/last30days-skill -g",
      "check": "test -d ~/.agents/skills/last30days/SKILL.md",
      "update": "npx skills update last30days",
      "check_latest": "gh api repos/mvanhorn/last30days-skill/releases/latest --jq .tag_name",
      "platform": "cross-platform",
      "optional": true
    }
  },
  "open_source_trim": {
    "keep": ["CORE", "ENHANCED"],
    "remove": ["ADVANCED"],
    "result": "12/15 commands, zero pip/npm deps for CORE, graceful degradation for ENHANCED"
  }
}
